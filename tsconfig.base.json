{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@cph/ui-components": ["packages/ui-components/src/index.tsx"],
      "@cph/utils": ["packages/utils/src/index.ts"],
      "@cph/feature-x": ["packages/feature-x/src/index.tsx"],
      "@cph/feature-y": ["packages/feature-y/src/index.tsx"]
    }
  }
}
